      "id": "eeb8c704-0736-4949-a973-98c26160232e",
      "name": "Transform SEO Metrics",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        704,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst pageRankings = [];\nconst keywordData = [];\nconst summaryStats = {\n  totalPages: 0,\n  averagePosition: 0,\n  topRankingPages: []\n};\n\nlet totalPosition = 0;\n\nfor (const item of items) {\n  const data = item.json;\n  \n  const page = {\n    url: data.link || '',\n    title: data.title || '',\n    snippet: data.snippet || '',\n    position: data.position || 0,\n    domain: data.domain || ''\n  };\n  \n  pageRankings.push(page);\n  totalPosition += page.position;\n  \n  const titleWords = (page.title || '').toLowerCase().split(/\\s+/).filter(word => word.length > 3);\n  const snippetWords = (page.snippet || '').toLowerCase().split(/\\s+/).filter(word => word.length > 3);\n  const keywords = [...new Set([...titleWords, ...snippetWords])];\n  \n  keywordData.push({\n    url: page.url,\n    keywords: keywords\n  });\n}\n\nsummaryStats.totalPages = items.length;\nsummaryStats.averagePosition = items.length > 0 ? (totalPosition / items.length).toFixed(2) : 0;\n\nsummaryStats.topRankingPages = pageRankings\n  .sort((a, b) => a.position - b.position)\n  .slice(0, 10)\n  .map(page => ({\n    url: page.url,\n    title: page.title,\n    position: page.position\n  }));\n\nconst keywordFrequency = {};\nkeywordData.forEach(item => {\n  item.keywords.forEach(keyword => {\n    keywordFrequency[keyword] = (keywordFrequency[keyword] || 0) + 1;\n  });\n});\n\nconst topKeywords = Object.entries(keywordFrequency)\n  .sort((a, b) => b[1] - a[1])\n  .slice(0, 20)\n  .map(([keyword, count]) => ({ keyword, count }));\n\nreturn [\n  {\n    json: {\n      summary: summaryStats,\n      topKeywords: topKeywords,\n      pageRankings: pageRankings,\n      searchQuery: $('Transform SEO Metrics').item.json.searchQuery,\n      totalResults: $('Transform SEO Metrics').item.json.totalResults\n    }\n  }\n];"
      },
