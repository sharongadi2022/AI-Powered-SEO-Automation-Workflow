              "id": "id-2",
              "name": "emailBody",
              "value": "=<!DOCTYPE html>\n<html>\n<head>\n<style>\nbody { font-family: Arial, sans-serif; line-height: 1.6; color: #333; margin: 0; padding: 0; }\n.container { max-width: 100%; margin: 0 auto; background: #ffffff; }\n.header { background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%); color: white; padding: 30px 20px; text-align: center; }\n.header h1 { margin: 0; font-size: 28px; }\n.header p { margin: 10px 0 0 0; font-size: 14px; opacity: 0.9; }\n.content { padding: 30px 20px; }\n.section { margin-bottom: 25px; }\n.section-title { color: #2c3e50; font-size: 20px; margin-bottom: 15px; padding-bottom: 8px; border-bottom: 2px solid #3498db; }\n.metrics-box { background: #e3f2fd; padding: 15px; border-radius: 5px; margin: 10px 0; border-left: 4px solid #2196f3; }\n.recommendations-box { background: #e8f5e9; padding: 15px; border-radius: 5px; margin: 10px 0; border-left: 4px solid #4caf50; }\n.info-box { background: #fff3e0; padding: 15px; border-radius: 5px; margin: 10px 0; border-left: 4px solid #ff9800; }\n.divider { height: 1px; background: #ecf0f1; margin: 20px 0; }\n.footer { background: #f5f5f5; padding: 20px; text-align: center; font-size: 12px; color: #777; }\nul { padding-left: 20px; }\nli { margin: 8px 0; }\n</style>\n</head>\n<body>\n<div class=\"container\">\n<div class=\"header\">\n<h1>📊 SEO Performance Report</h1>\n<p>{{ $now.toFormat('MMMM dd, yyyy') }}</p>\n</div>\n<div class=\"content\">\n<div class=\"section\">\n<div class=\"section-title\">Executive Summary</div>\n<div class=\"metrics-box\">\n<strong>Search Query:</strong> {{ $('Calculate SEO Trends').item.json.searchQuery }}<br>\n<strong>Total Results:</strong> {{ $('Calculate SEO Trends').item.json.totalResults.toLocaleString() }}<br>\n<strong>Average Position:</strong> {{ $('Calculate SEO Trends').item.json.summary.averagePosition }}<br>\n<strong>Pages Analyzed:</strong> {{ $('Calculate SEO Trends').item.json.summary.totalPages }}\n</div>\n</div>\n<div class=\"divider\"></div>\n<div class=\"section\">\n<div class=\"section-title\">AI-Powered Insights</div>\n<div class=\"info-box\">\n{{ $('SEO Insights AI Agent').item.json.output.replace(/[#*]/g, '').replace(/\\n/g, '<br>') }}\n</div>\n</div>\n<div class=\"divider\"></div>\n<div class=\"section\">\n<div class=\"section-title\">Top Performing Pages</div>\n<div class=\"metrics-box\">\n{{ $('Calculate SEO Trends').item.json.summary.topRankingPages.slice(0, 5).map((page, i) => `<strong>${i + 1}. ${page.title}</strong><br><small>Position: ${page.position} | ${page.url}</small>`).join('<br><br>') }}\n</div>\n</div>\n<div class=\"divider\"></div>\n<div class=\"section\">\n<div class=\"section-title\">Top Keywords</div>\n<div class=\"recommendations-box\">\n{{ $('Calculate SEO Trends').item.json.topKeywords.slice(0, 10).map((kw, i) => `${i + 1}. <strong>${kw.keyword}</strong> (${kw.count} occurrences)`).join('<br>') }}\n</div>\n</div>\n</div>\n<div class=\"footer\">\n<p>Generated automatically by your SEO Analytics Workflow</p>\n<p>© {{ $now.toFormat('yyyy') }} | Powered by n8n</p>\n</div>\n</div>\n</body>\n</html>",
